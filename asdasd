import subprocess
import time
import os
import requests
from datetime import datetime

# --- CONFIGURATION ---
PLACE_ID = "97598239454123"
ROBLOX_PACKAGE = "com.roblox.client"  # Main Roblox game client
CLONE_PACKAGE = "zam.deltb"           # The Delta clone container app

CHECK_INTERVAL = 10
SCREENSHOT_INTERVAL = 60  
ADB_DEVICE = "127.0.0.1:5555"

# Change "a" to your Discord Webhook URL
WEBHOOK_URL = "a" 
# ---------------------

def send_discord_log(message, include_screenshot=False, is_status_update=False):
    """Sends a text log and an optional screenshot to the Discord Webhook."""
    print(f"[Discord Log] {message}")
    
    if WEBHOOK_URL == "a" or not WEBHOOK_URL.startswith("http"):
        return

    header = "📸 **Roblox Status Update:**" if is_status_update else "⚙️ **Roblox Monitor Alert:**"
    payload = {"content": f"{header}\n{message}"}
    
    try:
        if include_screenshot:
            subprocess.run(f"adb -s {ADB_DEVICE} shell screencap -p /sdcard/roblox_snap.png", shell=True)
            subprocess.run(f"adb -s {ADB_DEVICE} pull /sdcard/roblox_snap.png ./roblox_snap.png", shell=True, stdout=subprocess.DEVNULL)
            
            if os.path.exists("./roblox_snap.png"):
                with open("./roblox_snap.png", "rb") as f:
                    files = {"file": ("screenshot.png", f, "image/png")}
                    requests.post(WEBHOOK_URL, data=payload, files=files)
                os.remove("./roblox_snap.png")
                return
        requests.post(WEBHOOK_URL, json=payload)
    except Exception as e:
        print(f"[!] Failed to send webhook payload: {e}")

def is_app_running(package_name):
    try:
        cmd = f"adb -s {ADB_DEVICE} shell pidof {package_name}"
        result = subprocess.run(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        return bool(result.stdout.strip())
    except Exception:
        return False

def is_correct_place(place_id):
    try:
        cmd = f"adb -s {ADB_DEVICE} shell dumpsys activity activities"
        result = subprocess.run(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        if f"placeId={place_id}" in result.stdout or f"games/{place_id}" in result.stdout:
            return True
        return False
    except Exception:
        return False

def launch_app_normally(package_name, app_label):
    print(f"[*] Starting up {app_label} ({package_name})...")
    cmd = f"adb -s {ADB_DEVICE} shell monkey -p {package_name} -c android.intent.category.LAUNCHER 1"
    subprocess.run(cmd, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def launch_both_apps(place_id, reason):
    """Launches Roblox first with the link, then opens the clone app second."""
    send_discord_log(f"⚠️ {reason}. Restarting setup in proper order (Roblox -> Clone)...", include_screenshot=True)
    
    # 1. Force stop BOTH apps to avoid overlapping process states
    subprocess.run(f"adb -s {ADB_DEVICE} shell am force-stop {ROBLOX_PACKAGE}", shell=True, stdout=subprocess.DEVNULL)
    subprocess.run(f"adb -s {ADB_DEVICE} shell am force-stop {CLONE_PACKAGE}", shell=True, stdout=subprocess.DEVNULL)
    time.sleep(1)
    
    # 2. STEP ONE: Launch the official Roblox app directly into the place ID (Bypasses popup)
    print(f"[*] Launching official Roblox client into Place ID {place_id}...")
    cmd_roblox = f'adb -s {ADB_DEVICE} shell am start -a android.intent.action.VIEW -d "roblox://placeId={place_id}" -p {ROBLOX_PACKAGE}'
    subprocess.run(cmd_roblox, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    
    # 3. Give Roblox 5 seconds to load up the engine and join the game
    print("[*] Waiting for Roblox to initialize...")
    time.sleep(5)
    
    # 4. STEP TWO: Launch the Clone layer app to overlay/inject on top of Roblox
    launch_app_normally(CLONE_PACKAGE, "Delta Clone Layer")
    
    # 5. Give you a 15-second grace period to handle any verification screens if needed
    print("[*] Waiting 15s for the clone app environment to hook onto Roblox...")
    time.sleep(15)

def main():
    print(f"[*] Ordered Co-Monitoring active. Target: {ADB_DEVICE}")
    print("-" * 60)
    
    send_discord_log(f"✅ Co-Monitor Online (Order: Roblox First -> Clone Second).\nMain: `{ROBLOX_PACKAGE}`\nClone: `{CLONE_PACKAGE}`")
    
    last_status_ok = None
    last_screenshot_time = 0
    
    while True:
        try:
            roblox_live = is_app_running(ROBLOX_PACKAGE)
            clone_live = is_app_running(CLONE_PACKAGE)
            correct_place = is_correct_place(PLACE_ID) if roblox_live else False
            current_time = time.time()
            
            # Trigger launch sequence if clone is dead, roblox is dead, or place ID mismatch
            if not clone_live or not roblox_live or not correct_place:
                last_status_ok = False
                
                if not roblox_live:
                    reason = "Main Roblox client process was completely closed"
                elif not clone_live:
                    reason = "Clone utility layer was closed"
                else:
                    reason = "Roblox is active but dropped to main menu or wrong place"
                    
                launch_both_apps(PLACE_ID, reason)
                last_screenshot_time = time.time()
            else:
                if last_status_ok != True:
                    print("[+] Setup stable. Roblox and Clone are active in correct order.")
                    last_status_ok = True
                    last_screenshot_time = current_time 
                
                # Periodic 1-minute visual assurance log
                if current_time - last_screenshot_time >= SCREENSHOT_INTERVAL:
                    timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
                    send_discord_log(f"🟢 System stable. Roblox running with clone active.\nTime: `{timestamp}`", include_screenshot=True, is_status_update=True)
                    last_screenshot_time = current_time
                    
            time.sleep(CHECK_INTERVAL)
        except KeyboardInterrupt:
            send_discord_log("❌ Monitor explicitly stopped by user inside Termux.")
            break

if __name__ == "__main__":
    main()
