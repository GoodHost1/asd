import os
import subprocess
import time
from datetime import datetime
import requests

# --- CONFIGURATION ---
PLACE_ID = "97598239454123"
ROBLOX_PACKAGE = "com.roblox.client"  # Hardcoded standard game package
USER_ID = 11083121033                # REPLACE with your numeric Roblox UserId
CHECK_INTERVAL = 60               # Check user status every 60 seconds
ADB_DEVICE = "127.0.0.1:5555"
WEBHOOK_URL = "a"                 # Replace with your Discord Webhook URL
# ---------------------


def get_player_presence(user_id):
    """
    Checks the official Roblox Presence API.
    Returns:
      0 = Offline
      1 = Online (Main Menu/Website)
      2 = InGame (Active inside a game server)
    """
    url = "https://presence.roblox.com/v1/presence/users"
    headers = {"Content-Type": "application/json", "Accept": "application/json"}
    payload = {"userIds": [user_id]}
    
    try:
        response = requests.post(url, json=payload, headers=headers, timeout=10)
        if response.status_code == 200:
            data = response.json()
            user_data = data.get("userPresences", [])
            if user_data:
                return user_data[0].get("userPresenceType", 0)
        return 0
    except Exception as e:
        print(f"[!] Error reading Roblox API: {e}")
        return 0


def send_discord_log(message, include_screenshot=False, is_status_update=False):
    """Sends a text log and an optional screenshot to the Discord Webhook."""
    print(f"[Discord Log] {message}")

    if WEBHOOK_URL == "a" or not WEBHOOK_URL.startswith("http"):
        return

    header = (
        "📸 **Roblox Live Status Update:**"
        if is_status_update
        else "⚙️ **Roblox Monitor Alert:**"
    )
    payload = {"content": f"{header}\n{message}"}

    try:
        if include_screenshot:
            subprocess.run(
                f"adb -s {ADB_DEVICE} shell screencap -p /sdcard/roblox_snap.png",
                shell=True,
            )
            subprocess.run(
                f"adb -s {ADB_DEVICE} pull /sdcard/roblox_snap.png ./roblox_snap.png",
                shell=True,
                stdout=subprocess.DEVNULL,
            )

            if os.path.exists("./roblox_snap.png"):
                with open("./roblox_snap.png", "rb") as f:
                    files = {"file": ("screenshot.png", f, "image/png")}
                    requests.post(WEBHOOK_URL, data=payload, files=files)
                os.remove("./roblox_snap.png")
                return

        requests.post(WEBHOOK_URL, json=payload)
    except Exception as e:
        print(f"[!] Failed to send webhook payload: {e}")


def is_roblox_running():
    """Checks the local Android environment for the client process."""
    try:
        cmd = f"adb -s {ADB_DEVICE} shell pidof {ROBLOX_PACKAGE}"
        result = subprocess.run(
            cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True
        )
        return bool(result.stdout.strip())
    except Exception:
        return False


def launch_roblox(place_id, reason):
    """Safely kills active sessions and issues cold intent routing triggers."""
    send_discord_log(
        f"⚠️ {reason}. Forcing relaunch to Place ID: `{place_id}`...",
        include_screenshot=True,
    )

    subprocess.run(
        f"adb -s {ADB_DEVICE} shell am force-stop {ROBLOX_PACKAGE}", shell=True, stdout=subprocess.DEVNULL
    )
    time.sleep(1)

    subprocess.run(
        f"adb -s {ADB_DEVICE} shell monkey -p {ROBLOX_PACKAGE} -c android.intent.category.LAUNCHER 1",
        shell=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    time.sleep(3)

    subprocess.run(
        f'adb -s {ADB_DEVICE} shell am start -a android.intent.action.VIEW -d "roblox://placeId={place_id}" -p {ROBLOX_PACKAGE}',
        shell=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def main():
    print(f"[*] API Presence Monitoring active. Target Device: {ADB_DEVICE}")
    print(f"[*] Tracking User ID: {USER_ID} | Target Package: {ROBLOX_PACKAGE}")
    print("-" * 65)
    
    send_discord_log(
        f"✅ Presence API Monitor Started!\nTargeting User ID: `{USER_ID}`\nPlace ID: `{PLACE_ID}`"
    )

    last_status_was_playing = None

    while True:
        try:
            # 1. Query online game server tracking profile
            presence = get_player_presence(USER_ID)
            # 2. Query local execution state
            local_running = is_roblox_running()
            
            timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')

            # State check: Must be running locally AND explicitly inside a game server session (Presence Type 2)
            if local_running and presence == 2:
                if last_status_was_playing != True:
                    print(f"[+] Player {USER_ID} detected safely inside the game instance.")
                    last_status_was_playing = True
                
                # Send standard reassurance status screenshot every check interval
                send_discord_log(
                    f"🟢 Account verified active inside game session.\nTime: `{timestamp}`",
                    include_screenshot=True,
                    is_status_update=True,
                )
            else:
                last_status_was_playing = False
                
                if not local_running:
                    reason = "Game client process completely dropped off locally"
                elif presence == 1:
                    reason = "Client is active, but account dropped back to main menu website layer"
                else:
                    reason = "Account detected completely offline / Disconnected from server"

                print(f"[!] Alert: {reason}. Launching app...")
                launch_roblox(PLACE_ID, reason)
                time.sleep(15)  # Extended launch cool-down period

            time.sleep(CHECK_INTERVAL)

        except KeyboardInterrupt:
            send_discord_log("❌ Monitor explicitly stopped by user inside Termux.")
            break


if __name__ == "__main__":
    main()
