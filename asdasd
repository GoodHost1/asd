import subprocess
import time
import os
import requests

# --- CONFIGURATION ---
PLACE_ID = "97598239454123"
ROBLOX_PACKAGE = "com.roblox.client"
CHECK_INTERVAL = 10
ADB_DEVICE = "127.0.0.1:5555"
WEBHOOK_URL = "a"
# ---------------------

def send_discord_log(message, include_screenshot=False):
    """Sends a text log and an optional screenshot to the Discord Webhook."""
    print(f"[Discord Log] {message}")
    
    payload = {"content": f"⚙️ **Roblox Monitor Alert:**\n{message}"}
    
    try:
        if include_screenshot:
            # 1. Take screenshot on Android device
            subprocess.run(f"adb -s {ADB_DEVICE} shell screencap -p /sdcard/roblox_snap.png", shell=True)
            # 2. Pull screenshot file into Termux local directory
            subprocess.run(f"adb -s {ADB_DEVICE} pull /sdcard/roblox_snap.png ./roblox_snap.png", shell=True, stdout=subprocess.DEVNULL)
            
            # 3. Send payload with file attachment
            if os.path.exists("./roblox_snap.png"):
                with open("./roblox_snap.png", "rb") as f:
                    files = {"file": ("screenshot.png", f, "image/png")}
                    requests.post(WEBHOOK_URL, data=payload, files=files)
                # Clean up local file copy
                os.remove("./roblox_snap.png")
                return
                
        # Send text-only if screenshot failed or wasn't requested
        requests.post(WEBHOOK_URL, json=payload)
    except Exception as e:
        print(f"[!] Failed to send webhook payload: {e}")

def is_roblox_running():
    try:
        cmd = f"adb -s {ADB_DEVICE} shell pidof {ROBLOX_PACKAGE}"
        result = subprocess.run(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        return bool(result.stdout.strip())
    except Exception:
        return False

def is_correct_place(place_id):
    try:
        cmd = f"adb -s {ADB_DEVICE} shell dumpsys activity activities"
        result = subprocess.run(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        if f"placeId={place_id}" in result.stdout or f"games/{place_id}" in result.stdout:
            return True
        return False
    except Exception:
        return False

def launch_roblox(place_id, reason):
    # Notify Discord that a relaunch scenario triggered
    send_discord_log(f"⚠️ {reason}. Forcing relaunch to Place ID: `{place_id}`...", include_screenshot=True)
    
    # Force close current instance
    subprocess.run(f"adb -s {ADB_DEVICE} shell am force-stop {ROBLOX_PACKAGE}", shell=True, stdout=subprocess.DEVNULL)
    time.sleep(1)
    
    # Launch standard activity base
    cmd1 = f"adb -s {ADB_DEVICE} shell monkey -p {ROBLOX_PACKAGE} -c android.intent.category.LAUNCHER 1"
    subprocess.run(cmd1, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    time.sleep(3)
    
    # Push target game deep link intent
    cmd2 = f'adb -s {ADB_DEVICE} shell am start -a android.intent.action.VIEW -d "roblox://placeId={place_id}"'
    subprocess.run(cmd2, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def main():
    print(f"[*] Monitoring active. Target Device: {ADB_DEVICE}")
    send_discord_log(f"✅ Monitor Started Successfully!\nTargeting Game Place ID: `{PLACE_ID}`")
    
    last_status_ok = None  # Tracking state changes to prevent spamming Discord
    
    while True:
        try:
            running = is_roblox_running()
            correct_place = is_correct_place(PLACE_ID) if running else False
            
            if running and correct_place:
                if last_status_ok != True:
                    print("[+] Roblox is running the correct game.")
                    last_status_ok = True
            elif running and not correct_place:
                last_status_ok = False
                launch_roblox(PLACE_ID, "Roblox is active but in the WRONG place or Main Menu")
                time.sleep(5)  # Add extra cooldown buffer for application initialization
            else:
                last_status_ok = False
                launch_roblox(PLACE_ID, "Roblox process was completely CLOSED")
                time.sleep(5)
                
            time.sleep(CHECK_INTERVAL)
        except KeyboardInterrupt:
            send_discord_log("❌ Monitor explicitly stopped by user inside Termux.")
            break

if __name__ == "__main__":
    main()
