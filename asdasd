import os
import subprocess
import time
from datetime import datetime
import requests

# --- CONFIGURATION ---
# --- CONFIGURATION ---
PLACE_ID = "97598239454123"
ROBLOX_PACKAGE = "com.roblox.client"  # Hardcoded standard game package
USER_ID = 11083121033                 # Your numeric Roblox UserId
CHECK_INTERVAL = 10                   # Check status every 10 seconds (aggressive)
FORCE_REJOIN_INTERVAL = 600           # Force re-join the game every 10 minutes (600s)
ADB_DEVICE = "127.0.0.1:5555"
WEBHOOK_URL = "a"                     # Replace with your Discord Webhook URL when ready
# ---------------------
# ---------------------


def get_player_presence(user_id):
    """
    Checks the official Roblox Presence API.
    Returns:
      0 = Offline
      1 = Online (Main Menu/Website)
      2 = InGame (Active inside a game server)
    """
    url = "https://presence.roblox.com/v1/presence/users"
    headers = {"Content-Type": "application/json", "Accept": "application/json"}
    payload = {"userIds": [user_id]}
    
    try:
        response = requests.post(url, json=payload, headers=headers, timeout=10)
        if response.status_code == 200:
            data = response.json()
            user_data = data.get("userPresences", [])
            if user_data:
                return user_data[0].get("userPresenceType", 0)
        return 0
    except Exception as e:
        print(f"[!] Error reading Roblox API: {e}")
        return 0


def send_discord_log(message, include_screenshot=False, is_status_update=False):
    """Sends a text log and an optional screenshot to the Discord Webhook."""
    print(f"[Discord Log] {message}")

    if WEBHOOK_URL == "a" or not WEBHOOK_URL.startswith("http"):
        return

    header = (
        "📸 **Roblox Live Status Update:**"
        if is_status_update
        else "⚙️ **Roblox Monitor Alert:**"
    )
    payload = {"content": f"{header}\n{message}"}

    try:
        if include_screenshot:
            subprocess.run(
                f"adb -s {ADB_DEVICE} shell screencap -p /sdcard/roblox_snap.png",
                shell=True,
            )
            subprocess.run(
                f"adb -s {ADB_DEVICE} pull /sdcard/roblox_snap.png ./roblox_snap.png",
                shell=True,
                stdout=subprocess.DEVNULL,
            )

            if os.path.exists("./roblox_snap.png"):
                with open("./roblox_snap.png", "rb") as f:
                    files = {"file": ("screenshot.png", f, "image/png")}
                    requests.post(WEBHOOK_URL, data=payload, files=files)
                os.remove("./roblox_snap.png")
                return

        requests.post(WEBHOOK_URL, json=payload)
    except Exception as e:
        print(f"[!] Failed to send webhook payload: {e}")


def is_roblox_running():
    """Checks the local Android environment for the client process."""
    try:
        cmd = f"adb -s {ADB_DEVICE} shell pidof {ROBLOX_PACKAGE}"
        result = subprocess.run(
            cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True
        )
        return bool(result.stdout.strip())
    except Exception:
        return False


def launch_roblox(place_id, reason):
    """Safely kills active sessions and issues cold intent routing triggers."""
    send_discord_log(
        f"⚠️ {reason}. Forcing relaunch to Place ID: `{place_id}`...",
        include_screenshot=True,
    )

    # Force stop to dismiss any crash popups or freeze hangs
    subprocess.run(
        f"adb -s {ADB_DEVICE} shell am force-stop {ROBLOX_PACKAGE}", shell=True, stdout=subprocess.DEVNULL
    )
    time.sleep(1)

    subprocess.run(
        f"adb -s {ADB_DEVICE} shell monkey -p {ROBLOX_PACKAGE} -c android.intent.category.LAUNCHER 1",
        shell=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    time.sleep(3)

    subprocess.run(
        f'adb -s {ADB_DEVICE} shell am start -a android.intent.action.VIEW -d "roblox://placeId={place_id}" -p {ROBLOX_PACKAGE}',
        shell=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def main():
    print(f"[*] API Presence, Crash, & Auto-Rejoin active. Target Device: {ADB_DEVICE}")
    print(f"[*] Tracking User ID: {USER_ID} | Force Re-join Interval: {FORCE_REJOIN_INTERVAL}s")
    print("-" * 75)
    
    send_discord_log(
        f"✅ Monitor Online!\nTargeting User ID: `{USER_ID}`\nForced re-join active every 10 minutes."
    )

    last_status_was_playing = None
    last_forced_launch_time = time.time()  # Track the starting execution point

    while True:
        try:
            current_time = time.time()
            timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')

            # 1. PRIORITY CHECK: Has 10 minutes passed since the last launch?
            if current_time - last_forced_launch_time >= FORCE_REJOIN_INTERVAL:
                print(f"[*] 10-minute timer reached. Triggering scheduled forced server re-join...")
                launch_roblox(PLACE_ID, "Scheduled 10-minute automated server refresh")
                last_forced_launch_time = current_time
                last_status_was_playing = False
                time.sleep(15)
                continue

            # 2. STANDARD STATE CHECKS: Check process and API status every 60 seconds
            presence = get_player_presence(USER_ID)
            local_running = is_roblox_running()

            # State check: Must be running locally AND explicitly inside a game server session (Presence Type 2)
            if local_running and presence == 2:
                if last_status_was_playing != True:
                    print(f"[+] Player {USER_ID} verified active inside the game.")
                    last_status_was_playing = True
                
                # Calculate time remaining until next forced re-join for logs
                time_until_rejoin = int(FORCE_REJOIN_INTERVAL - (current_time - last_forced_launch_time))
                minutes_left = time_until_rejoin // 60
                
                send_discord_log(
                    f"🟢 Account active inside game session.\nNext forced re-join in: `{minutes_left}m`\nTime: `{timestamp}`",
                    include_screenshot=True,
                    is_status_update=True,
                )
            else:
                last_status_was_playing = False
                
                if not local_running:
                    reason = "💥 Roblox crashed or process dropped off locally"
                elif presence == 1:
                    reason = "🛑 Client active, but game disconnected to website/menu layer"
                else:
                    reason = "❌ Account went offline (Silent freeze or server disconnection)"

                print(f"[!] Alert: {reason}. Re-launching app...")
                launch_roblox(PLACE_ID, reason)
                last_forced_launch_time = time.time()  # Reset the 10-min clock since we had to force-open it anyway
                time.sleep(15)

            time.sleep(CHECK_INTERVAL)

        except KeyboardInterrupt:
            send_discord_log("❌ Monitor explicitly stopped by user inside Termux.")
            break


if __name__ == "__main__":
    main()
