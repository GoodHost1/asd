import os
import subprocess
import time
from datetime import datetime
from PIL import Image, ImageOps
import pytesseract
import requests

# --- CONFIGURATION ---
PLACE_ID = "97598239454123"
ROBLOX_PACKAGE = "com.roblox.client"
CHECK_INTERVAL = 10
LAUNCH_GRACE_PERIOD = 30
ADB_DEVICE = "127.0.0.1:5555"
WEBHOOK_URL = "a"

# --- OCR SETTINGS ---
OCR_CHECK_INTERVAL = 120
OCR_FAILURE_LIMIT = 3
OCR_KEYWORDS = [
    "speed hub",
    "localplayer",
    "automatically",
    "discord",
    "seeds",
    "garden",
    "sell",
]
# ---------------------


def ui_detected():
    try:
        subprocess.run(
            f"adb -s {ADB_DEVICE} shell screencap -p /sdcard/check.png",
            shell=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

        subprocess.run(
            f"adb -s {ADB_DEVICE} pull /sdcard/check.png ./check.png",
            shell=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

        img = Image.open("./check.png")

        # grayscale full screen to catch both Game and Speed Hub UIs
        img = ImageOps.grayscale(img)

        text = pytesseract.image_to_string(img).lower()

        print("\n===== OCR OUTPUT =====")
        print(text)
        print("======================\n")

        matches = 0
        for keyword in OCR_KEYWORDS:
            if keyword in text:
                matches += 1

        print(f"[OCR] Found {matches}/{len(OCR_KEYWORDS)} keywords")

        if os.path.exists("./check.png"):
            os.remove("./check.png")

        # Require at least 3 matches
        return matches >= 3

    except Exception as e:
        print(f"[OCR ERROR] {e}")
        return False


def send_discord_log(message, include_screenshot=False, is_status_update=False):
    """Sends a text log and an optional screenshot to the Discord Webhook."""
    print(f"[Discord Log] {message}")

    header = (
        "📸 **Roblox Live Status Update:**"
        if is_status_update
        else "⚙️ **Roblox Monitor Alert:**"
    )
    payload = {"content": f"{header}\n{message}"}

    try:
        if include_screenshot:
            subprocess.run(
                f"adb -s {ADB_DEVICE} shell screencap -p /sdcard/roblox_snap.png",
                shell=True,
            )
            subprocess.run(
                f"adb -s {ADB_DEVICE} pull /sdcard/roblox_snap.png ./roblox_snap.png",
                shell=True,
                stdout=subprocess.DEVNULL,
            )

            if os.path.exists("./roblox_snap.png"):
                with open("./roblox_snap.png", "rb") as f:
                    files = {"file": ("screenshot.png", f, "image/png")}
                    requests.post(WEBHOOK_URL, data=payload, files=files)
                os.remove("./roblox_snap.png")
                return

        requests.post(WEBHOOK_URL, json=payload)
    except Exception as e:
        print(f"[!] Failed to send webhook payload: {e}")


def is_roblox_running():
    try:
        cmd = f"adb -s {ADB_DEVICE} shell pidof {ROBLOX_PACKAGE}"
        result = subprocess.run(
            cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True
        )
        return bool(result.stdout.strip())
    except Exception:
        return False


def is_correct_place(place_id):
    try:
        cmd = f"adb -s {ADB_DEVICE} shell dumpsys activity activities"
        result = subprocess.run(
            cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True
        )
        if (
            f"placeId={place_id}" in result.stdout
            or f"games/{place_id}" in result.stdout
        ):
            return True
        return False
    except Exception:
        return False


def launch_roblox(place_id, reason):
    send_discord_log(
        f"⚠️ {reason}. Forcing relaunch to Place ID: `{place_id}`...",
        include_screenshot=True,
    )

    subprocess.run(
        f"adb -s {ADB_DEVICE} shell am force-stop {ROBLOX_PACKAGE}", shell=True
    )

    time.sleep(1)

    subprocess.run(
        f"adb -s {ADB_DEVICE} shell monkey -p {ROBLOX_PACKAGE} -c android.intent.category.LAUNCHER 1",
        shell=True,
    )

    time.sleep(3)

    subprocess.run(
        f'adb -s {ADB_DEVICE} shell am start -a android.intent.action.VIEW -d "roblox://placeId={place_id}" -p {ROBLOX_PACKAGE}',
        shell=True,
    )

    print(f"[*] Waiting {LAUNCH_GRACE_PERIOD}s for Roblox to load...")
    time.sleep(LAUNCH_GRACE_PERIOD)


def main():
    print(f"[*] Monitoring active. Target Device: {ADB_DEVICE}")
    send_discord_log(
        f"✅ Monitor Started Successfully!\nTargeting Game Place ID: `{PLACE_ID}`"
    )

    last_ocr_check = 0
    ocr_failures = 0

    while True:
        try:
            running = is_roblox_running()
            correct_place = is_correct_place(PLACE_ID) if running else False
            current_time = time.time()

            if running and correct_place:
                # Only OCR every 60 seconds
                if current_time - last_ocr_check >= OCR_CHECK_INTERVAL:
                    print("[*] Running OCR verification...")

                    if ui_detected():
                        ocr_failures = 0
                        print("[+] UI verification passed.")
                    else:
                        ocr_failures += 1
                        print(
                            f"[!] OCR failed ({ocr_failures}/{OCR_FAILURE_LIMIT})"
                        )

                        if ocr_failures >= OCR_FAILURE_LIMIT:
                            launch_roblox(
                                PLACE_ID, "Speed Hub/Game UI not detected"
                            )
                            ocr_failures = 0

                    last_ocr_check = current_time

            elif running and not correct_place:
                launch_roblox(PLACE_ID, "Wrong place detected")
                ocr_failures = 0
                last_ocr_check = time.time()

            else:
                launch_roblox(PLACE_ID, "Roblox closed")
                ocr_failures = 0
                last_ocr_check = time.time()

            time.sleep(CHECK_INTERVAL)

        except KeyboardInterrupt:
            send_discord_log("❌ Monitor explicitly stopped by user inside Termux.")
            break


if __name__ == "__main__":
    main()
