import subprocess
import time
import os
import requests
from datetime import datetime

# --- CONFIGURATION ---
ROBLOX_PACKAGE = "com.roblox.client"  # Main Roblox game client
CLONE_PACKAGE = "zam.deltb"           # The Delta clone launcher tool

CHECK_INTERVAL = 10
SCREENSHOT_INTERVAL = 60  
ADB_DEVICE = "127.0.0.1:5555"

# Change "a" to your Discord Webhook URL when ready
WEBHOOK_URL = "a" 
# ---------------------

def send_discord_log(message, include_screenshot=False, is_status_update=False):
    """Sends a text log and an optional screenshot to the Discord Webhook."""
    print(f"[Discord Log] {message}")
    
    if WEBHOOK_URL == "a" or not WEBHOOK_URL.startswith("http"):
        return

    header = "📸 **Roblox Keep-Alive Status:**" if is_status_update else "⚙️ **Roblox Keep-Alive Alert:**"
    payload = {"content": f"{header}\n{message}"}
    
    try:
        if include_screenshot:
            subprocess.run(f"adb -s {ADB_DEVICE} shell screencap -p /sdcard/roblox_snap.png", shell=True)
            subprocess.run(f"adb -s {ADB_DEVICE} pull /sdcard/roblox_snap.png ./roblox_snap.png", shell=True, stdout=subprocess.DEVNULL)
            
            if os.path.exists("./roblox_snap.png"):
                with open("./roblox_snap.png", "rb") as f:
                    files = {"file": ("screenshot.png", f, "image/png")}
                    requests.post(WEBHOOK_URL, data=payload, files=files)
                os.remove("./roblox_snap.png")
                return
        requests.post(WEBHOOK_URL, json=payload)
    except Exception as e:
        print(f"[!] Failed to send webhook payload: {e}")

def is_app_running(package_name):
    try:
        cmd = f"adb -s {ADB_DEVICE} shell pidof {package_name}"
        result = subprocess.run(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        return bool(result.stdout.strip())
    except Exception:
        return False

def launch_app_normally(package_name, app_label):
    print(f"[*] Bringing back {app_label} ({package_name})...")
    # Tries direct main activity launch first, falls back to monkey if needed
    cmd = f"adb -s {ADB_DEVICE} shell am start -n {package_name}/com.multi.clone.MainActivity || adb -s {ADB_DEVICE} shell monkey -p {package_name} 1"
    subprocess.run(cmd, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def main():
    print(f"[*] Keep-Alive Monitoring active targeting {ADB_DEVICE}.")
    print(f"[*] Main: {ROBLOX_PACKAGE} | Clone: {CLONE_PACKAGE}")
    print("-" * 65)
    
    send_discord_log(f"✅ Keep-Alive Guardian Online!\nMonitoring: `{ROBLOX_PACKAGE}` and `{CLONE_PACKAGE}`")
    
    last_status_ok = None
    last_screenshot_time = time.time()
    
    while True:
        try:
            roblox_live = is_app_running(ROBLOX_PACKAGE)
            clone_live = is_app_running(CLONE_PACKAGE)
            current_time = time.time()
            
            # --- Check Clone Package ---
            if not clone_live:
                print(f"[!] {CLONE_PACKAGE} dropped! Reopening...")
                send_discord_log(f"⚠️ `{CLONE_PACKAGE}` was found closed. Reviving application.")
                launch_app_normally(CLONE_PACKAGE, "Clone Launcher")
                last_status_ok = False
                time.sleep(3)
                
            # --- Check Roblox Package ---
            if not roblox_live:
                print(f"[!] {ROBLOX_PACKAGE} dropped! Reopening...")
                send_discord_log(f"⚠️ `{ROBLOX_PACKAGE}` was found closed. Reviving application.")
                launch_app_normally(ROBLOX_PACKAGE, "Roblox Client")
                last_status_ok = False
                time.sleep(3)

            # --- Status Updates ---
            if roblox_live and clone_live:
                if last_status_ok != True:
                    print("[+] Both apps are currently running fine.")
                    last_status_ok = True
                
                # Send the scheduled 1-minute visual update
                if current_time - last_screenshot_time >= SCREENSHOT_INTERVAL:
                    timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
                    send_discord_log(f"🟢 Both applications are safely kept alive.\nTime: `{timestamp}`", include_screenshot=True, is_status_update=True)
                    last_screenshot_time = current_time
                    
            time.sleep(CHECK_INTERVAL)
        except KeyboardInterrupt:
            send_discord_log("❌ Keep-Alive Monitor stopped by user.")
            break

if __name__ == "__main__":
    main()
